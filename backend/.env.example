# Local development (copy to .env)
PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/dripkart
# Or MongoDB Atlas:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dripkart?retryWrites=true&w=majority

JWT_SECRET=generate-a-long-random-string-min-32-chars
CLIENT_ORIGIN=http://localhost:5173
ALLOW_VERCEL_PREVIEWS=true

ADMIN_EMAIL=admin@dripkart.com
ADMIN_PASSWORD=admin123

# Razorpay test keys — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
# Alias also supported:
# RAZORPAY_SECRET=xxxx
